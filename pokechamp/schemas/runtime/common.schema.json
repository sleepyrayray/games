{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokechamp.local/schemas/runtime/common.schema.json",
  "$defs": {
    "pokemonTypeId": {
      "type": "string",
      "enum": [
        "normal",
        "fire",
        "water",
        "electric",
        "grass",
        "ice",
        "fighting",
        "poison",
        "ground",
        "flying",
        "psychic",
        "bug",
        "rock",
        "ghost",
        "dragon",
        "dark",
        "steel",
        "fairy"
      ]
    },
    "floorLevel": {
      "type": "integer",
      "enum": [
        8, 12, 15, 19, 23, 26, 30, 34, 37, 41, 44, 48, 52, 55, 59, 63, 66, 70
      ]
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "idString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$"
    },
    "statBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hp",
        "attack",
        "defense",
        "specialAttack",
        "specialDefense",
        "speed"
      ],
      "properties": {
        "hp": {
          "type": "integer",
          "minimum": 1
        },
        "attack": {
          "type": "integer",
          "minimum": 1
        },
        "defense": {
          "type": "integer",
          "minimum": 1
        },
        "specialAttack": {
          "type": "integer",
          "minimum": 1
        },
        "specialDefense": {
          "type": "integer",
          "minimum": 1
        },
        "speed": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "spriteSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["front"],
      "properties": {
        "front": {
          "type": "string",
          "minLength": 1
        },
        "back": {
          "type": "string",
          "minLength": 1
        },
        "icon": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "moveCategory": {
      "type": "string",
      "enum": ["physical", "special", "status"]
    },
    "moveEffectTag": {
      "type": "string",
      "enum": [
        "none",
        "stat-boost",
        "stat-drop",
        "protect",
        "heal",
        "status-apply",
        "recoil",
        "drain",
        "priority",
        "multi-hit",
        "other"
      ]
    },
    "moveSet": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/idString"
      },
      "uniqueItems": true
    },
    "battleReadyPokemonRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "battlePokemonId",
        "speciesId",
        "formId",
        "name",
        "types",
        "baseStats",
        "legalLevelRange",
        "floorTypes",
        "movesetsByFloorLevel",
        "sprite"
      ],
      "properties": {
        "battlePokemonId": {
          "$ref": "#/$defs/idString"
        },
        "speciesId": {
          "$ref": "#/$defs/idString"
        },
        "formId": {
          "$ref": "#/$defs/idString"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/pokemonTypeId"
          },
          "uniqueItems": true
        },
        "baseStats": {
          "$ref": "#/$defs/statBlock"
        },
        "legalLevelRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "max": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "floorTypes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/pokemonTypeId"
          },
          "uniqueItems": true
        },
        "movesetsByFloorLevel": {
          "type": "object",
          "patternProperties": {
            "^(8|12|15|19|23|26|30|34|37|41|44|48|52|55|59|63|66|70)$": {
              "$ref": "#/$defs/moveSet"
            }
          },
          "additionalProperties": false
        },
        "sprite": {
          "$ref": "#/$defs/spriteSet"
        }
      }
    },
    "moveRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "moveId",
        "name",
        "type",
        "category",
        "power",
        "accuracy",
        "pp",
        "priority",
        "target",
        "effectTag",
        "allowedInGame"
      ],
      "properties": {
        "moveId": {
          "$ref": "#/$defs/idString"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/pokemonTypeId"
        },
        "category": {
          "$ref": "#/$defs/moveCategory"
        },
        "power": {
          "type": "integer",
          "minimum": 0
        },
        "accuracy": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "pp": {
          "type": "integer",
          "minimum": 1
        },
        "priority": {
          "type": "integer"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "effectTag": {
          "$ref": "#/$defs/moveEffectTag"
        },
        "effectData": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        },
        "allowedInGame": {
          "type": "boolean"
        }
      }
    },
    "typeTheme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["palette", "materialTags", "propTags"],
      "properties": {
        "palette": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/hexColor"
          }
        },
        "materialTags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "propTags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "typeMetadataRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typeId", "name", "color", "uiAccent", "floorTheme"],
      "properties": {
        "typeId": {
          "$ref": "#/$defs/pokemonTypeId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "$ref": "#/$defs/hexColor"
        },
        "uiAccent": {
          "$ref": "#/$defs/hexColor"
        },
        "floorTheme": {
          "$ref": "#/$defs/typeTheme"
        }
      }
    },
    "starterPoolRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grass", "fire", "water"],
      "properties": {
        "grass": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/idString"
          },
          "uniqueItems": true
        },
        "fire": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/idString"
          },
          "uniqueItems": true
        },
        "water": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/idString"
          },
          "uniqueItems": true
        }
      }
    },
    "floorLevelRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floorNumber", "level"],
      "properties": {
        "floorNumber": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18
        },
        "level": {
          "$ref": "#/$defs/floorLevel"
        }
      }
    },
    "playerHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floor", "floorType", "speciesId", "formId", "level"],
      "properties": {
        "floor": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18
        },
        "floorType": {
          "$ref": "#/$defs/pokemonTypeId"
        },
        "speciesId": {
          "$ref": "#/$defs/idString"
        },
        "formId": {
          "$ref": "#/$defs/idString"
        },
        "level": {
          "$ref": "#/$defs/floorLevel"
        }
      }
    },
    "currentRunPokemon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speciesId", "formId", "level", "moves"],
      "properties": {
        "speciesId": {
          "$ref": "#/$defs/idString"
        },
        "formId": {
          "$ref": "#/$defs/idString"
        },
        "level": {
          "$ref": "#/$defs/floorLevel"
        },
        "moves": {
          "$ref": "#/$defs/moveSet"
        }
      }
    },
    "runStateRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runId",
        "playerName",
        "currentFloor",
        "currentFloorType",
        "usedSpecies",
        "usedBattlePokemon",
        "playerHistory",
        "currentPokemon",
        "nextDoorTypes",
        "seed"
      ],
      "properties": {
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "playerName": {
          "type": "string",
          "minLength": 1
        },
        "currentFloor": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18
        },
        "currentFloorType": {
          "$ref": "#/$defs/pokemonTypeId"
        },
        "usedSpecies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/idString"
          },
          "uniqueItems": true
        },
        "usedBattlePokemon": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/idString"
          },
          "uniqueItems": true
        },
        "playerHistory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/playerHistoryEntry"
          }
        },
        "currentPokemon": {
          "$ref": "#/$defs/currentRunPokemon"
        },
        "nextDoorTypes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/pokemonTypeId"
          },
          "uniqueItems": true
        },
        "seed": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
