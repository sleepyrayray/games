{
  "name": "pokechamp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "data:import": "node --experimental-strip-types ./scripts/import/fetch-pokeapi.ts",
    "data:build": "node --experimental-strip-types ./scripts/build-data/build-runtime-data.ts",
    "data:validate": "node --experimental-strip-types ./scripts/build-data/validate-runtime-data.ts",
    "data:sync": "npm run data:import && npm run data:build && npm run data:validate",
    "phase3:simulate": "node --experimental-strip-types ./scripts/phase3/simulate-runs.ts",
    "phase3:validate": "node --experimental-strip-types ./scripts/phase3/simulate-runs.ts --runs 500",
    "phase4:validate": "node --experimental-strip-types ./scripts/phase4/validate-flow.ts",
    "phase5:validate": "node --experimental-strip-types ./scripts/phase5/validate-battle.ts",
    "phase5:simulate": "node --experimental-strip-types ./scripts/phase5/simulate-battles.ts"
  },
  "dependencies": {
    "phaser": "^3.88.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.4"
  }
}
